{
	"name": "data_catalogue",
	"version": "2.1.3",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5174 --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:sync": "DB_MIGRATING=true drizzle-kit introspect",
		"db:migrate": "DB_MIGRATING=true drizzle-kit migrate",
		"db:drop": "DB_MIGRATING=true drizzle-kit drop",
		"db:seed": "",
		"db:push": "drizzle-kit push"
	},
	"devDependencies": {
		"@arturoguzman/art-ui": "^2.7.1",
		"@azure/storage-blob": "^12.31.0",
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@imago/config": "workspace:*",
		"@imago/ui": "workspace:*",
		"@ory/client-fetch": "^1.22.28",
		"@ory/keto-namespace-types": "0.13.0-alpha.0",
		"@playwright/test": "^1.58.2",
		"@rollup/plugin-json": "^6.1.0",
		"@sentry/sveltekit": "^10.43.0",
		"@sindresorhus/slugify": "^3.0.0",
		"@svar-ui/svelte-grid": "^2.5.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tus/azure-store": "^2.0.0",
		"@tus/file-store": "^2.0.0",
		"@tus/server": "^2.3.0",
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@uppy/core": "^5.2.0",
		"@uppy/svelte": "^5.2.0",
		"@uppy/tus": "^5.1.1",
		"@vitest/browser": "^4.1.4",
		"arktype": "^2.2.0",
		"dompurify": "^3.3.3",
		"dotenv": "^17.3.1",
		"drizzle-arktype": "^0.1.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"luxon": "^3.7.2",
		"marked": "^16.4.2",
		"nanoid": "^5.1.7",
		"pg": "^8.20.0",
		"pg-native": "^3.7.0",
		"pino": "^10.3.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"rollup-plugin-import-css": "^4.2.0",
		"svelte": "^5.53.13",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.1",
		"typescript-svelte-plugin": "^0.3.50",
		"uuid": "^13.0.0",
